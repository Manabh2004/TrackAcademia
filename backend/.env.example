NODE_ENV=development
PORT=5000

# Local database:
# Leave the MySQL vars empty to use SQLite automatically.
DB_DIALECT=sqlite
SQLITE_PATH=./database.sqlite

# MySQL database:
# Uncomment and fill these if you want MySQL instead of SQLite.
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=academic_app
# DB_USER=root
# DB_PASS=

JWT_SECRET=replace_this_with_a_long_random_secret
ENABLE_BOOTSTRAP_DATA=false

ANTHROPIC_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
